@namespace MyClass.Web.Components
@rendermode InteractiveServer
@implements IDisposable
@inject ISessionStorageService SessionStorage
@inject ILoginStateService LoginStateService

@*
    RoleGate Component
    Controls access to content based on the current user's role (Teacher or Student).
    Displays appropriate messages for loading, unauthenticated, and unauthorized states.
*@

@* Loading state: Show spinner while checking login state *@
@if (!_loadedLoginState)
{
    <LoadingIndicator Text="Checking access..." />
}
@* Unauthenticated state: No user is currently logged in *@
else if (LoginStateService.Current is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
        Sign in to continue.
    </MudAlert>
}
@* Access granted for teachers when RequireTeacher is true *@
else if (RequireTeacher && LoginStateService.Current.IsTeacher)
{
    @ChildContent
}
@* Access granted for students when RequireTeacher is false *@
else if (!RequireTeacher && !LoginStateService.Current.IsTeacher)
{
    @ChildContent
}
@* Access denied: User role does not match requirements *@
else
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
        @DeniedMessage
    </MudAlert>
}
