@namespace MyClass.Web.Components
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject ILoginStateService LoginStateService
@inject ISessionStorageService SessionStorage
@inject IQuizAnswerService QuizAnswerService
@inject IQuizContentService QuizContentService
@inject IOptions<QuizOptions> QuizOptions
@inject NavigationManager Navigation

@if (_isLoading)
{
    <LoadingIndicator Text="Loading quiz answer..." />
}
else
{
    <MudStack Spacing="3" Class="quiz-answer-shell">
        <MudStack Spacing="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                @* Quiz title *@
                <MudText Typo="Typo.h5">@QuizTitle</MudText>
            </MudStack>

            @if (QuestionProgress.Count > 0)
            {
                @* Question progress row *@
                <div class="quiz-progress-row" aria-label="Quiz question progress">
                    <MudText Typo="Typo.h6">Questions: </MudText>
                    @foreach (var item in QuestionProgress)
                    {
                        @* Question progress button *@
                        <span class="@GetProgressCircleClass(item)"
                              title="@GetProgressCircleTitle(item)">
                            @(item.QuestionIndex + 1)
                        </span>
                    }
                </div>
            }

            @if (ShowRevealMessage)
            {
                @* Answer reveal message *@
                <div class="@GetRevealMessageClass()">
                    @RevealMessage
                </div>
            }
            else
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                    @* Quiz status message *@
                    <MudText Typo="Typo.subtitle1"
                             Color="Color.Secondary"
                             Align="Align.Center"
                             Class="quiz-status-message">
                        @StatusMessage
                    </MudText>
                    @if (ShowTimer)
                    {
                        @* Question timer *@
                        <MudChip T="string"
                                 Color="@(IsTimerRunning ? Color.Primary : Color.Default)"
                                 Variant="Variant.Filled">
                            Timer: @FormatRemaining(TimerRemaining)
                        </MudChip>
                    }
                </MudStack>
            }
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(_imageMessage))
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">@_imageMessage</MudAlert>
        }
        else if (!string.IsNullOrWhiteSpace(_imageDataUri))
        {
            @* Question image *@
            <img class="quiz-answer-question-image"
                 src="@_imageDataUri"
                 alt="@QuestionImageAltText" />
        }

        @if (ShowAnswerButtons)
        {
            @* Answer instruction text *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Align="Align.Center">
                Click on button with correct answer number
            </MudText>
            @* Answer button list *@
            <div class="quiz-answer-buttons">
                @foreach (var answer in AnswerChoices)
                {
                    @* Answer button *@
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Secondary"
                               Class="quiz-answer-button"
                               Disabled="_isSubmitting"
                               OnClick="() => SubmitAnswerAsync(answer)">
                        @answer
                    </MudButton>
                }
            </div>
        }
        else if (_stateResult?.Value?.HasInProgressAnswer == true)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
                No answer choices are available for this question.
            </MudAlert>
        }
    </MudStack>
}
