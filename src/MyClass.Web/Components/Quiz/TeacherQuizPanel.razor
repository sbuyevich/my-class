@namespace MyClass.Web.Components
@rendermode InteractiveServer
@implements IDisposable
@inject ILoginStateService LoginStateService
@inject ISessionStorageService SessionStorage
@inject IQuizContentService QuizContentService
@inject IActiveQuizSelectionService ActiveQuizSelectionService
@inject IQuizAutoNextStateService AutoNextStateService
@inject IQuizNotificationService QuizNotificationService
@inject IQuizSessionService QuizSessionService
@inject IOptions<QuizOptions> QuizOptions

@if (_isLoading)
{
    <LoadingIndicator Text="Loading quiz..." />
}
else if (_stateResult is null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled">Unable to load quiz.</MudAlert>
}
else if (!_stateResult.Succeeded)
{
    <MudStack Spacing="2">
        @if (_availableQuizzesResult is not null && !_availableQuizzesResult.Succeeded)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">@_availableQuizzesResult.Message</MudAlert>
        }
        else if (_availableQuizzes.Count == 0)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">No valid quizzes are available.</MudAlert>
        }

        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">@_stateResult.Message</MudAlert>
    </MudStack>
}
else if (_stateResult.Value is not null)
{
    var state = _stateResult.Value;

    <MudGrid Spacing="3" Class="teacher-quiz-grid" Justify="Justify.Center">
        <MudItem md="10">
            <MudStack Spacing="3">
                @if (_availableQuizzesResult is not null && !_availableQuizzesResult.Succeeded)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">@_availableQuizzesResult.Message</MudAlert>
                }
                else if (_availableQuizzes.Count == 0)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">No valid quizzes are available.</MudAlert>
                }
                else
                {
                    @* Quiz selector control *@
                    <MudSelect T="string"
                               Value="@(_selectedQuizPath ?? string.Empty)"
                               ValueChanged="HandleQuizSelectedAsync"
                               Label="Quiz"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Disabled="_isWorking">
                        @foreach (var quiz in _availableQuizzes)
                        {
                            <MudSelectItem T="string" Value="@quiz.Path">@quiz.Name</MudSelectItem>
                        }
                    </MudSelect>
                }

                @* Buttons panel *@
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h4">@state.QuizTitle</MudText>
                    <MudStack Spacing="1" AlignItems="AlignItems.End">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            @if (!state.HasSession)
                            {
                                @* Start quiz *@
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.PlayArrow"
                                           Disabled="@(_isWorking || !HasSelectedQuiz)"
                                           OnClick="StartQuestionAsync">
                                    Start
                                </MudButton>
                            }
                            else
                            {
                                @* Restart quiz *@
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Secondary"
                                           StartIcon="@Icons.Material.Filled.Refresh"
                                           Disabled="@(_isWorking || !HasSelectedQuiz)"
                                           OnClick="RestartQuizAsync">
                                    Restart
                                </MudButton>
                            }

                            @if (state.HasSession && !state.IsComplete)
                            {
                                @* Finish question *@
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Warning"
                                           StartIcon="@Icons.Material.Filled.Stop"
                                           Disabled="@(_isWorking || state.CurrentQuestion?.IsInProgress != true)"
                                           OnClick="FinishQuestionAsync">
                                    Finish
                                </MudButton>
                                @* Show answer *@
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Secondary"
                                           StartIcon="@Icons.Material.Filled.Visibility"
                                           Disabled="@(_isWorking || state.CurrentQuestion is null || state.CurrentQuestion.IsAnswerRevealed)"
                                           OnClick="ShowAnswerAsync">
                                    Answer
                                </MudButton>
                                @* Next question *@
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           EndIcon="@Icons.Material.Filled.SkipNext"
                                           Disabled="@(_isWorking || state.CurrentQuestion?.IsInProgress == true || IsLastQuestion(state.CurrentQuestion))"
                                           OnClick="MoveNextQuestionAsync">
                                    Next
                                </MudButton>
                            }
                        </MudStack>

                        @if (state.HasSession && !state.IsComplete)
                        {
                            @* Auto next *@
                            <MudSwitch T="bool"
                                       Value="_autoNext"
                                       ValueChanged="HandleAutoNextChanged"
                                       Color="Color.Primary"
                                       Disabled="@(_isWorking || IsLastQuestion(state.CurrentQuestion))"
                                       Label="Auto Next" />
                        }
                    </MudStack>
                </MudStack>

                @if (state.IsComplete)
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Filled">
                        Quiz complete.
                    </MudAlert>
                }
                else if (state.CurrentQuestion is null)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        Start the quiz when students are ready.
                    </MudAlert>
                }
                else
                {
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                            @* Question progress label *@
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                                Question @(state.CurrentQuestion.QuestionIndex + 1) of @state.CurrentQuestion.QuestionCount
                            </MudText>
                            @* Question timer *@
                            <MudChip T="string"
                                     Color="@(state.CurrentQuestion.IsInProgress ? Color.Primary : Color.Default)"
                                     Variant="Variant.Filled">
                                Timer: @FormatRemaining(state.CurrentQuestion.Remaining)
                            </MudChip>
                        </MudStack>

                        @if (!string.IsNullOrWhiteSpace(_imageMessage))
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">@_imageMessage</MudAlert>
                        }
                        else if (!string.IsNullOrWhiteSpace(_imageDataUri))
                        {
                            @* Question image control *@
                            <img class="quiz-question-image"
                                 src="@_imageDataUri"
                                 alt="@state.CurrentQuestion.Title" />
                        }
                    </MudStack>
                }
            </MudStack>
        </MudItem>

        <MudItem md="10">
            <MudStack Spacing="2">
                @* Student search label *@
                <MudTextField T="string"
                              Value="_studentSearchText"
                              ValueChanged="HandleStudentSearchChanged"
                              Label="Search students"
                              Placeholder="Student name or user name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Immediate="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable="true" />

                @* Student answer grid control *@
                <MudTable T="QuizStudentAnswerStatus"
                          Items="FilteredStudents"
                          Dense="true"
                          Hover="true"
                          Elevation="1"
                          AllowUnsorted="false">
                    <HeaderContent>
                        <MudTh>
                            <MudTableSortLabel SortBy="new Func<QuizStudentAnswerStatus, object>(student => student.DisplayName)">
                                Student
                            </MudTableSortLabel>
                        </MudTh>
                        <MudTh>
                            <MudTableSortLabel SortBy="new Func<QuizStudentAnswerStatus, object>(student => GetAnswerResultSortValue(student, state.CurrentQuestion?.IsAnswerRevealed == true))">
                                Answer
                            </MudTableSortLabel>
                        </MudTh>
                        @if (state.CurrentQuestion?.IsAnswerRevealed == true)
                        {
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<QuizStudentAnswerStatus, object>(student => student.AnswerElapsed ?? TimeSpan.MaxValue)">
                                    Answer Time
                                </MudTableSortLabel>
                            </MudTh>
                        }
                        <MudTh Style="text-align:center;">
                            <MudTableSortLabel SortBy="new Func<QuizStudentAnswerStatus, object>(student => student.CorrectCount)">
                                Correct Answers
                            </MudTableSortLabel>
                        </MudTh>
                        <MudTh Style="text-align:center;">
                            <MudTableSortLabel SortBy="new Func<QuizStudentAnswerStatus, object>(student => student.IncorrectCount)">
                                Incorrect Answers
                            </MudTableSortLabel>
                        </MudTh>
                        <MudTh Style="text-align:center;">
                            <MudTableSortLabel SortBy="new Func<QuizStudentAnswerStatus, object>(student => student.TotalAnswerTime)">
                                Total Answer Time
                            </MudTableSortLabel>
                        </MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Student">@context.DisplayName</MudTd>
                        <MudTd DataLabel="Answer">
                            @* Answer result *@
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="@GetAnswerResultColor(context, state.CurrentQuestion?.IsAnswerRevealed == true)"
                                     Variant="Variant.Filled">
                                @GetAnswerResultText(context, state.CurrentQuestion?.IsAnswerRevealed == true)
                            </MudChip>
                        </MudTd>
                        @if (state.CurrentQuestion?.IsAnswerRevealed == true)
                        {
                            <MudTd DataLabel="Answer Time">@FormatAnswerElapsed(context)</MudTd>
                        }
                        <MudTd DataLabel="Correct" Style="text-align:center;">@context.CorrectCount (@FormatPercent(context.PercentCorrect))</MudTd>
                        <MudTd DataLabel="Incorrect" Style="text-align:center;">@context.IncorrectCount (@FormatPercent(100 - context.PercentCorrect))</MudTd>
                        <MudTd DataLabel="Total Time" Style="text-align:center;">@FormatTotalAnswerTime(context.TotalAnswerTime)</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudStack>
        </MudItem>
    </MudGrid>
}
