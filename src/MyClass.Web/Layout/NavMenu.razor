@rendermode InteractiveServer
@implements IDisposable
@inject ILoginStateService LoginStateService

<MudStack Spacing="0" Class="pa-3">
       
    <MudNavMenu Dense="true" Rounded="true">
        @if (IsSignedIn)
        {
            <MudNavLink Href="/home" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
        }

        @if (IsStudent)
        {
            <MudNavLink Href="/quiz-answer" Icon="@Icons.Material.Filled.CheckCircle">Quiz Answer</MudNavLink>
        }

        @if (IsTeacher)
        {
            <MudDivider Class="my-2" />
            <MudNavLink Href="/students" Icon="@Icons.Material.Filled.Groups">Students</MudNavLink>
            <MudNavLink Href="/quiz" Icon="@Icons.Material.Filled.Quiz">Quiz</MudNavLink>
            <MudNavLink Href="/quiz-result" Icon="@Icons.Material.Filled.TableView">Quiz Result</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/school-class" Icon="@Icons.Material.Filled.School">School/Class</MudNavLink>
        }
    </MudNavMenu>
</MudStack>
