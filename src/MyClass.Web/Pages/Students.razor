@page "/students"
@rendermode InteractiveServer

<PageTitle>My Class</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <div>
            <MudText Typo="Typo.h4">Students</MudText>
        </div>

        @if (_studentsResult?.Succeeded == true)
        {
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                    @StudentCount student@(StudentCount == 1 ? string.Empty : "s")
                </MudChip>
                <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined">
                    @ActiveStudentCount active
                </MudChip>
            </MudStack>
        }
    </MudStack>

    <StudentGrid CurrentClass="CurrentClass" StudentsLoaded="OnStudentsLoaded" />
</MudStack>
