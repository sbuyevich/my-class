@page "/quiz-result"
@rendermode InteractiveServer

<PageTitle>Quiz Result</PageTitle>

<RoleGate RequireTeacher="true" DeniedMessage="Only teachers can view quiz results.">
    <MudStack Spacing="3">
        @* Quiz result header *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
            <div>
                @* Quiz result title *@
                <MudText Typo="Typo.h4">@(_stateResult?.Value?.QuizName ?? "Quiz Result")</MudText>
            </div>

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                @if (_stateResult?.Succeeded == true && _stateResult.Value?.HasResults == true)
                {
                    @* Student count chip *@
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                        @_stateResult.Value.StudentSummaries.Count student@(_stateResult.Value.StudentSummaries.Count == 1 ? string.Empty : "s")
                    </MudChip>
                    @* Question count chip *@
                    <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined">
                        @_stateResult.Value.QuestionSummaries.Count question@(_stateResult.Value.QuestionSummaries.Count == 1 ? string.Empty : "s")
                    </MudChip>
                }

                @* Export results button *@
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.FileDownload"
                           Disabled="@(!HasResults || _isExporting)"
                           OnClick="ExportCsvAsync">
                    @(_isExporting ? "Exporting..." : "Export")
                </MudButton>
            </MudStack>
        </MudStack>

        @if (_isLoading)
        {
            <LoadingIndicator Text="Loading quiz results..." />
        }
        else if (_stateResult is null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                Unable to load quiz results.
            </MudAlert>
        }
        else if (!_stateResult.Succeeded)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
                @_stateResult.Message
            </MudAlert>
        }
        else if (_stateResult.Value?.HasResults != true)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                No active quiz results yet.
            </MudAlert>
        }
        else
        {
            <MudStack Spacing="3">
                @* Student results panel *@
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Spacing="3">
                        @* Student results title *@
                        <MudText Typo="Typo.h6">Students</MudText>

                        @* Student search field *@
                        <MudTextField T="string"
                                      Value="_studentSearchText"
                                      ValueChanged="HandleStudentSearchChanged"
                                      Label="Search students"
                                      Placeholder="Student name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Clearable="true" />

                        @* Student results table *@
                        <MudTable T="QuizResultStudentSummary"
                                  Items="FilteredStudentSummaries"
                                  Dense="true"
                                  Hover="true"
                                  Elevation="0"
                                  AllowUnsorted="false">
                            <HeaderContent>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<QuizResultStudentSummary, object>(row => row.StudentDisplayName)">
                                        Student
                                    </MudTableSortLabel>
                                </MudTh>
                                <MudTh Style="text-align:center;">
                                    <MudTableSortLabel SortBy="new Func<QuizResultStudentSummary, object>(row => row.CorrectCount)">
                                        Correct Answers
                                    </MudTableSortLabel>
                                </MudTh>
                                <MudTh Style="text-align:center;">
                                    <MudTableSortLabel SortBy="new Func<QuizResultStudentSummary, object>(row => row.IncorrectCount)">
                                        Incorrect Answers
                                    </MudTableSortLabel>
                                </MudTh>
                                <MudTh Style="text-align:center;">
                                    <MudTableSortLabel SortBy="new Func<QuizResultStudentSummary, object>(row => row.TotalAnswerTime)">
                                        Total Answer Time
                                    </MudTableSortLabel>
                                </MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Student">@context.StudentDisplayName</MudTd>
                                <MudTd DataLabel="Correct" Style="text-align:center;">@context.CorrectCount (@FormatPercent(context.PercentCorrect))</MudTd>
                                <MudTd DataLabel="Incorrect" Style="text-align:center;">@context.IncorrectCount (@FormatPercent(100 - context.PercentCorrect))</MudTd>
                                <MudTd DataLabel="Time" Style="text-align:center;">@FormatTime(context.TotalAnswerTime)</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudStack>
                </MudPaper>

                @* Question results panel *@
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Spacing="3">
                        @* Question results title *@
                        <MudText Typo="Typo.h6">Questions</MudText>

                        @* Question results table *@
                        <MudTable T="QuizResultQuestionSummary"
                                  Items="QuestionSummaries"
                                  Dense="true"
                                  Hover="true"
                                  Elevation="0"
                                  AllowUnsorted="false">
                            <HeaderContent>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<QuizResultQuestionSummary, object>(row => row.QuestionText)">
                                        Question
                                    </MudTableSortLabel>
                                </MudTh>
                                <MudTh Style="text-align:center;">
                                    <MudTableSortLabel SortBy="new Func<QuizResultQuestionSummary, object>(row => row.CorrectCount)">
                                        Students with Correct Answer
                                    </MudTableSortLabel>
                                </MudTh>
                                <MudTh Style="text-align:center;">
                                    <MudTableSortLabel SortBy="new Func<QuizResultQuestionSummary, object>(row => row.IncorrectCount)">
                                        Students with Incorrect Answer
                                    </MudTableSortLabel>
                                </MudTh>
                                <MudTh Style="text-align:center;">
                                    <MudTableSortLabel SortBy="new Func<QuizResultQuestionSummary, object>(row => row.TotalAnswerTime)">
                                        Answer Time
                                    </MudTableSortLabel>
                                </MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Question">@context.QuestionText</MudTd>
                                <MudTd DataLabel="Correct" Style="text-align:center;">@context.CorrectCount (@FormatPercent(context.PercentCorrect))</MudTd>
                                <MudTd DataLabel="Incorrect" Style="text-align:center;">@context.IncorrectCount (@FormatPercent(100 - context.PercentCorrect))</MudTd>
                                <MudTd DataLabel="Time" Style="text-align:center;">@FormatTime(context.TotalAnswerTime)</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudStack>
                </MudPaper>
            </MudStack>
        }
    </MudStack>
</RoleGate>
