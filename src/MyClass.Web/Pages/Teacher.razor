@page "/teacher"
@rendermode InteractiveServer
@inject IUrlService UrlService
@inject IQrCodeService QrCodeService
@inject IClassContextService ClassContextService
@inject ILoginStateService LoginStateService
@inject ISessionStorageService SessionStorage
@inject IStudentService StudentService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>My Class - Teacher</PageTitle>

<RoleGate RequireTeacher="true" DeniedMessage="Only teachers can use the teacher landing page.">
    <MudStack Spacing="3">
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                <MudText Typo="Typo.h6" Color="Color.Secondary">Click the Reset button to make sure all students are inactive before they log in or register.</MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.RestartAlt"
                           Disabled="_isResettingStudents"
                           OnClick="ResetActiveStudentsAsync">
                    @(_isResettingStudents ? "Resetting..." : "Reset")
                </MudButton>
                <MudText Typo="Typo.h6" Color="Color.Secondary">Then ask students to load the URL below.</MudText>
            </MudStack>
        </MudAlert>

        @if (_studentEntryUrlResult is null)
        {
            <LoadingIndicator Text="Preparing student connection..." />
        }
        else if (!_studentEntryUrlResult.Succeeded)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                @_studentEntryUrlResult.Message
            </MudAlert>
        }
        else
        {
            <MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="1" Class="pa-4" Style="min-height: 18rem;">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6" Color="Color.Secondary">Please enter this URL in your browser address bar:</MudText>
                            <MudText Typo="Typo.h5" Style="overflow-wrap: anywhere;">@_studentEntryUrlResult.Value</MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="1" Class="pa-4" Style="min-height: 18rem;">
                        <MudStack Spacing="2" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6" Color="Color.Secondary">Or scan the QR code below with your mobile device:</MudText>
                            <img src="@_qrCodeDataUri"
                                 style="width: min(100%, 18rem); aspect-ratio: 1; image-rendering: pixelated;"
                                 alt="QR code for the student login URL" />
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </MudStack>
</RoleGate>
