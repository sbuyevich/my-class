@page "/"
@page "/login"
@rendermode InteractiveServer
@inject ISessionStorageService SessionStorage
@inject ILoginStateService LoginStateService
@inject NavigationManager Navigation

<PageTitle>My Class</PageTitle>

<div class="login-shell">
    <MudPaper Class="login-panel pa-5" Elevation="8">
        <LoginForm CurrentClass="CurrentClass"
                   Succeeded="HandleSucceededAsync"
                   RegisterRequested="GoToRegister" />
    </MudPaper>
</div>
